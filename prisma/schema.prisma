generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  manager
  member
}

enum Score {
  none
  ka
  ryo
  yu
}

enum Necessity {
  required
  half
}

enum Judgment {
  qualified
  unqualified
  none
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique @db.VarChar(255)
  password_hash           String    @db.VarChar(255)
  name                    String    @db.VarChar(100)
  division                String?   @db.VarChar(100)
  joined_at               DateTime? @db.Date
  role                    UserRole
  manager_id              String?
  wants_president_meeting Boolean   @default(false)
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  manager              User?              @relation("ManagerMembers", fields: [manager_id], references: [id])
  members              User[]             @relation("ManagerMembers")
  career_plans         CareerPlan[]
  evaluations          Evaluation[]
  role_members         RoleMember[]
  monthly_records      MonthlyRecord[]
  assignment_histories AssignmentHistory[]

  @@map("users")
}

model AssignmentHistory {
  id          String @id @default(uuid())
  user_id     String
  fiscal_year Int
  division    String @db.VarChar(100)

  user User @relation(fields: [user_id], references: [id])

  @@map("assignment_histories")
}

model CareerPlan {
  id                     String   @id @default(uuid())
  user_id                String
  fiscal_year            Int
  current_roles_self     String[]
  current_roles_official String[]
  current_position       String?  @db.VarChar(50)
  future_roles_self      String[]
  future_position_self   String?  @db.VarChar(50)
  future_comment         String?  @db.Text
  achievements_pr        String?  @db.Text
  next_year_goals        String?  @db.Text
  interim_comment        String?  @db.Text
  final_comment          String?  @db.Text

  user  User   @relation(fields: [user_id], references: [id])
  goals Goal[]

  @@unique([user_id, fiscal_year])
  @@map("career_plans")
}

model Goal {
  id                String  @id @default(uuid())
  career_plan_id    String
  category          String? @db.VarChar(100)
  title             String  @db.VarChar(255)
  goal_criteria     String? @db.Text
  action            String? @db.Text
  period            String? @db.VarChar(50)
  progress          String? @db.Text
  progress_official String? @db.Text
  sort_order        Int     @default(0)

  career_plan     CareerPlan     @relation(fields: [career_plan_id], references: [id])
  goal_eval_links GoalEvalLink[]

  @@map("goals")
}

model GoalEvalLink {
  goal_id  String
  eval_uid String @db.VarChar(20)

  goal            Goal           @relation(fields: [goal_id], references: [id])
  evaluation_item EvaluationItem @relation(fields: [eval_uid], references: [uid])

  @@id([goal_id, eval_uid])
  @@map("goal_eval_links")
}

model EvaluationItem {
  uid           String  @id @db.VarChar(20)
  target        String  @db.VarChar(50)
  target_no     Int?
  category      String  @db.VarChar(100)
  category_no   Int?
  item_no       Int
  name          String  @db.VarChar(255)
  description   String? @db.Text
  eval_criteria String? @db.Text
  two_year_rule Boolean @default(false)

  evaluations        Evaluation[]
  role_eval_mappings RoleEvalMapping[]
  goal_eval_links    GoalEvalLink[]
  allocations        Allocation[]

  @@map("evaluation_items")
}

model Evaluation {
  id             String  @id @default(uuid())
  user_id        String
  fiscal_year    Int
  eval_uid       String  @db.VarChar(20)
  self_score     Score?
  self_reason    String? @db.Text
  manager_score  Score?
  manager_reason String? @db.Text

  user            User           @relation(fields: [user_id], references: [id])
  evaluation_item EvaluationItem @relation(fields: [eval_uid], references: [uid])

  @@unique([user_id, fiscal_year, eval_uid])
  @@map("evaluations")
}

model Role {
  id                String  @id @default(uuid())
  classification    String  @db.VarChar(50)
  name              String  @db.VarChar(100)
  weight            Int     @default(1)
  description       String? @db.Text
  required_criteria String? @db.Text
  special_criteria  String? @db.Text

  role_eval_mappings RoleEvalMapping[]
  role_members       RoleMember[]

  @@unique([classification, name])
  @@map("roles")
}

model RoleEvalMapping {
  id             String    @id @default(uuid())
  role_id        String
  eval_uid       String    @db.VarChar(20)
  necessity      Necessity
  required_level Score

  role            Role           @relation(fields: [role_id], references: [id])
  evaluation_item EvaluationItem @relation(fields: [eval_uid], references: [uid])

  @@map("role_eval_mappings")
}

model RoleMember {
  id              String   @id @default(uuid())
  user_id         String
  role_id         String
  fiscal_year     Int
  judgment        Judgment
  qualified_count Int?
  total_count     Int?

  user User @relation(fields: [user_id], references: [id])
  role Role @relation(fields: [role_id], references: [id])

  @@unique([user_id, role_id, fiscal_year])
  @@map("role_members")
}

model Allocation {
  id          String @id @default(uuid())
  fiscal_year Int
  division    String @db.VarChar(100)
  eval_uid    String @db.VarChar(20)
  weight      Int

  evaluation_item EvaluationItem @relation(fields: [eval_uid], references: [uid])

  @@unique([fiscal_year, division, eval_uid])
  @@map("allocations")
}

model MonthlyRecord {
  id           String   @id @default(uuid())
  user_id      String
  fiscal_year  Int
  record_month DateTime @db.Date
  product      String   @db.VarChar(100)
  task         String   @db.VarChar(255)
  done         Boolean  @default(false)

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, record_month, product, task])
  @@map("monthly_records")
}
